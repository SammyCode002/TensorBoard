#!/usr/bin/env bash

# Load modules
# Load the Tensorflow module (required)
module load lang/Python/3.10.8-GCCcore-12.2.0

# Activate the virtual environment
# Update this path to match your virtual environment location
source "${HOME}/tensorboard_env/bin/activate"

# Start the authentication reverse proxy in the background
bin/authrevproxy.py --app-port="$app_port" --proxy-port="$proxy_port" &

# Set the working directory to the home directory
cd "${HOME}"

# Launch the TensorBoard server
tensorboard --logdir=/tmp \
            --host=127.0.0.1 \
            --port="${app_port}"
